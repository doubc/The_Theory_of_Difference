        {"name": "人民币汇率", "id": "exchange_rate", "direction": "正向", "weight": 0.25},
        {"name": "进口关税+滑准税", "id": "tariff", "direction": "正向", "weight": 0.2},
        {"name": "进口配额政策", "id": "quota", "direction": "复杂", "weight": 0.1}
