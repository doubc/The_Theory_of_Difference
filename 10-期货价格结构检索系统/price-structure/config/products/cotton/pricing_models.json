        {"name": "纺织业PMI", "id": "textile_pmi", "direction": "正向", "weight": 0.2},
        {"name": "残差/政策冲击", "id": "residual", "direction": "不定", "weight": 0.1}
      ],
      "description": "棉花定价核心是全球供需平衡表。库消比低于50%时价格弹性急剧放大（2010-2011年行情）。ICE通过进口成本传导。纺织PMI代表下游需求强度。",
      "dominantPhase": "库消比处于极端水平时模型最有效",
      "limitation": "忽略中国收储/抛储政策对国内价格的独立影响",
      "trackingVariables": ["全球库消比", "ICE价格", "纺织开机率", "进口量"],
      "linkToEntities": ["VAR_110", "VAR_111", "VAR_115"],
      "linkToRelations": ["R_320", "R_321", "R_329"]
    },
    {
      "id": "M_026",
