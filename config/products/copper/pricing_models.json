{
  "commodity": "铜",
  "symbol": "CU",
  "version": "1.3.0",
  "models": [
    {
      "id": "M_001",
      "name": "铜的实际利率定价模型",
      "domain": "宏观金融定价",
      "groundBase": "order",
      "formula": "Δln(Cu) = α + β1*Δln(1/RealRate) + β2*Δln(DXY) + β3*Δln(PMI) + ε",
      "variables": [
        {
          "name": "实际利率（10年期TIPS收益率）",
          "id": "VAR_004_derived",
          "direction": "反向",
          "weight": 0.35
        },
        {
          "name": "美元指数DXY",
          "id": "VAR_003",
          "direction": "反向",
          "weight": 0.25
        },
        {
          "name": "全球制造业PMI",
          "id": "VAR_007",
          "direction": "正向",
          "weight": 0.3
        },
        {
          "name": "残差/供给冲击",
          "id": "residual",
          "direction": "不定",
          "weight": 0.1
        }
      ],
      "description": "铜作为金融属性最强的工业金属，实际利率是其机会成本，美元是其计价货币，PMI是其需求代理变量。该模型在宏观交易中解释力最强（R²约0.6-0.7）。",
      "dominantPhase": "当铜的金融属性主导时（如美联储政策拐点、全球宏观交易），该模型有效性最高",
      "limitation": "忽视库存结构、矿山供给中断、废铜替代等微观因素，在供应严重紧张或宽松时解释力下降",
      "trackingVariables": [
        "TIPS收益率",
        "DXY",
        "全球PMI",
        "模型残差（作为供给冲击度量）"
      ],
      "linkToEntities": [
        "VAR_004",
        "VAR_003",
        "VAR_007"
      ],
      "linkToRelations": [
        "R_205",
        "R_206"
      ]
    },
    {
      "id": "M_002",
      "name": "铜的库存-价差动力学模型",
      "domain": "微观结构定价",
      "groundBase": "marginal",
      "formula": "ΔSpread(Cash-3M) = f(Inventory/Consumption, Seasonality, TradeFlow)",
      "variables": [
        {
          "name": "全球显性库存/周度消费量（库存消费比）",
          "id": "VAR_069_derived",
          "direction": "反向",
          "weight": 0.45
        },
        {
          "name": "LME现货/3月升贴水",
          "id": "VAR_067_derived",
          "direction": "正向（自我强化）",
          "weight": 0.3
        },
        {
          "name": "洋山铜溢价（中国进口需求代理）",
          "id": "VAR_070",
          "direction": "正向",
          "weight": 0.15
        },
        {
          "name": "季节性因子（Q4/Q1消费旺季）",
          "id": "seasonal",
          "direction": "正向",
          "weight": 0.1
        }
      ],
      "description": "库存是供需平衡的最直接指标。当库存降至临界水平（全球消费不足1周），现货升水将加速走强，铜价弹性急剧放大。Backwardation结构下空头展期亏损，形成自我强化的逼仓压力。",
      "dominantPhase": "当库存处于极端低位（<30万吨）或高位（>60万吨）时，该模型定价权重超过宏观模型",
      "limitation": "库存数据存在统计滞后，且不能完全覆盖隐性库存和贸易商库存，在融资铜盛行时信号失真",
      "trackingVariables": [
