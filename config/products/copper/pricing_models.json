        {
          "name": "铜精矿TC/RC加工费",
          "id": "VAR_068",
          "direction": "反向（TC低→矿紧→铜价涨）",
          "weight": 0.35
        },
        {
          "name": "精废价差",
          "id": "VAR_069_derived",
          "direction": "反向（价差扩→废铜替代→压精铜价）",
